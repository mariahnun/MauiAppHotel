<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.HospedagemContratada"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource Gray100}">

    <ContentPage.Resources>
        <Style TargetType="Frame">
            <Setter Property="BackgroundColor" Value="#77a493" />
        </Style>
    </ContentPage.Resources>

    <VerticalStackLayout VerticalOptions="CenterAndExpand"
                         Padding="10"
                         Spacing="2">
        

        <Label Text="Estadia"
               FontFamily="Kalam"
               FontSize="40"
               TextColor="#020202"
               HorizontalTextAlignment="Center"/>

        <Frame Padding="10">
            <VerticalStackLayout>
                <Grid RowDefinitions="Auto, Auto"
                      ColumnDefinitions="*, *, 2*">

                    <Label Grid.Row="0" Grid.Column="0"
                           Text="Adultos: " />

                    <Label Grid.Row="0" Grid.Column="1"
                           TextColor="#000000"
                           Text="{Binding Value}"
                           BindingContext="{x:Reference stp_adultos}"/>

                    <Stepper Grid.Row="0" Grid.Column="5" 
                             
                             x:Name="stp_adultos"
                             Minimum="0"
                             Maximum="10"
                             Increment="1" />

                    <Label Grid.Row="1" Grid.Column="0"
                           Text="Crianças: " />

                    <Label Grid.Row="1" Grid.Column="1"
                           TextColor="#000000"
                           Text="{Binding Value}"
                           BindingContext="{x:Reference stp_criancas}"/>

                    <Stepper Grid.Row="1" Grid.Column="5"
                             x:Name="stp_criancas"
                             Minimum="0"
                             Maximum="10"
                             Increment="1" />
                </Grid>

                <Frame Padding="10" Margin="10">
                    <VerticalStackLayout>

                        <Label Text="Escolha sua Suíte"
                               TextTransform="Uppercase"
                               FontSize="Subtitle"
                               TextColor="#000000"/>

                        <Picker x:Name="pck_quarto"
                            Title="Selecione sua Acomodação"
                            ItemDisplayBinding="{Binding Descricao}">
                        </Picker>
                    </VerticalStackLayout>
                </Frame>

                <Frame Padding="10"
                       Margin="5">
                    <VerticalStackLayout Spacing="5">

                        <Label Text="Período da Estadia"
                               TextTransform="Uppercase"
                               FontSize="Subtitle"
                               TextColor="#000000"/>

                        <HorizontalStackLayout HorizontalOptions="CenterAndExpand">
                            <Label Text="Check-in:" />
                            <DatePicker x:Name="dtpck_checkin"
                                        Format="dd/MM/yyyy" />
                        </HorizontalStackLayout>

                        <HorizontalStackLayout HorizontalOptions="CenterAndExpand">
                            <Label Text="Check-out:" />
                            <DatePicker x:Name="dtpck_checkout"
                                        Format="dd/MM/yyyy" />
                        </HorizontalStackLayout>

                    </VerticalStackLayout>
                </Frame>
                <Frame Margin="1">
                    <VerticalStackLayout>
                        
                       
                        <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, *">
                            <Label Grid.Row="0" Grid.Column="0" Text="Valor diária crianças:" />
                            <Label Grid.Row="1" Grid.Column="0" Text="{Binding Source={x:Reference pck_quarto}, Path=SelectedItem.ValorDiariaCrianca, StringFormat='R${0}'}" />

                            <Label Grid.Row="0" Grid.Column="1" Text="Valor diária adultos:" />
                            <Label Grid.Row="1" Grid.Column="1" Text="{Binding Source={x:Reference pck_quarto}, Path=SelectedItem.ValorDiariaAdulto, StringFormat='R${0}'}" />

                        </Grid>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </Frame>
        
        

        <Grid RowDefinitions="Auto, Auto"
      ColumnDefinitions="*, *">

            <Button Text="Voltar" 
            HorizontalOptions="Center"
            Clicked="Button_Clicked_2" Grid.Row="0" Grid.Column="0"/>

            <Button Text="Avançar" 
        HorizontalOptions="Center"
        Clicked="Button_Clicked" Grid.Row="0" Grid.Column="1"/>
        </Grid>

    </VerticalStackLayout>
</ContentPage>